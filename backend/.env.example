# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGO_URL=mongodb://kulimaiq:kulimaiq_secret@localhost:27017/kulimaiq?authSource=admin
MONGO_DB=kulimaiq

# Username / password used by docker-compose to init the MongoDB container
MONGO_USERNAME=kulimaiq
MONGO_PASSWORD=kulimaiq_secret

# ── Security ──────────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_IN_PRODUCTION_USE_LONG_RANDOM_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── ML model ──────────────────────────────────────────────────────────────────
# Path to the trained MobileNetV2 weights file (relative to backend/)
MODEL_WEIGHTS_PATH=model_weights/kulimaiq_mobilenet.pth
ML_CONFIDENCE_THRESHOLD=0.50

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated origins allowed to call the API.
# Use ["*"] for development; restrict in production.
ALLOWED_ORIGINS=["*"]
